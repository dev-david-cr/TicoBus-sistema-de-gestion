<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="SistemaTicoBus.MAUI.Views.DetalleReservaPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource PageBackground}"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <Grid Row="0" Padding="20,50,20,15" ColumnDefinitions="Auto,*" BackgroundColor="{StaticResource SurfaceBackground}">
            <Label
                Grid.Column="0"
                Text="&#8592;"
                FontSize="22"
                TextColor="{StaticResource Primary}"
                VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="BtnVolver_Tapped" />
                </Label.GestureRecognizers>
            </Label>
            <Label
                Grid.Column="1"
                Text="Detalle del Viaje"
                FontSize="20"
                FontAttributes="Bold"
                TextColor="{StaticResource TextPrimary}"
                Margin="15,0,0,0"
                VerticalOptions="Center" />
        </Grid>

        <ScrollView Grid.Row="1">
            <Grid Padding="20" RowDefinitions="Auto,Auto">

                <ActivityIndicator
                    x:Name="LoadingIndicator"
                    Grid.Row="0"
                    IsRunning="True"
                    Color="{StaticResource Primary}"
                    VerticalOptions="Center"
                    Margin="0,40,0,0" />

                <Label
                    x:Name="LabelError"
                    Grid.Row="0"
                    Text="No se pudo cargar la reserva."
                    FontSize="14"
                    TextColor="{StaticResource ErrorText}"
                    HorizontalOptions="Center"
                    IsVisible="False"
                    Margin="0,40,0,0" />

                <VerticalStackLayout x:Name="ContenidoDetalle" Grid.Row="1" Spacing="18" IsVisible="False">

                    <Border
                        BackgroundColor="{StaticResource SurfaceBackground}"
                        Padding="20"
                        Stroke="{StaticResource BorderColor}"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="12">

                            <Grid ColumnDefinitions="*,Auto">
                                <Label
                                    Grid.Column="0"
                                    x:Name="LabelRuta"
                                    FontSize="20"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource TextPrimary}" />
                                <Border
                                    Grid.Column="1"
                                    BackgroundColor="{StaticResource SuccessBackground}"
                                    Padding="10,4"
                                    StrokeThickness="0"
                                    VerticalOptions="Start">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12" />
                                    </Border.StrokeShape>
                                    <Label
                                        x:Name="LabelEstado"
                                        FontSize="11"
                                        TextColor="{StaticResource SuccessText}" />
                                </Border>
                            </Grid>

                            <BoxView HeightRequest="1" BackgroundColor="{StaticResource BorderColor}" Margin="0,5" />

                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" RowSpacing="15">
                                <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="2">
                                    <Label Text="FECHA DE SALIDA" FontSize="10" TextColor="{StaticResource TextMuted}" />
                                    <Label x:Name="LabelFechaSalida" FontSize="14" TextColor="{StaticResource TextPrimary}" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="2">
                                    <Label Text="LLEGADA ESTIMADA" FontSize="10" TextColor="{StaticResource TextMuted}" />
                                    <Label x:Name="LabelFechaLlegada" FontSize="14" TextColor="{StaticResource TextPrimary}" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="2">
                                    <Label Text="ASIENTO" FontSize="10" TextColor="{StaticResource TextMuted}" />
                                    <Label x:Name="LabelAsiento" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource AccentBlue}" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="2">
                                    <Label Text="MONTO PAGADO" FontSize="10" TextColor="{StaticResource TextMuted}" />
                                    <Label x:Name="LabelMonto" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                </VerticalStackLayout>
                            </Grid>

                        </VerticalStackLayout>
                    </Border>

                    <Border
                        BackgroundColor="{StaticResource SurfaceBackground}"
                        Padding="20"
                        Stroke="{StaticResource BorderColor}"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="10">
                            <Label Text="UNIDAD Y CHOFER" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                            <Label x:Name="LabelPlaca" FontSize="14" TextColor="{StaticResource TextPrimary}" />
                            <Label x:Name="LabelChofer" FontSize="14" TextColor="{StaticResource TextPrimary}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        BackgroundColor="{StaticResource SurfaceBackground}"
                        Padding="20"
                        Stroke="{StaticResource BorderColor}"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="10">
                            <Label Text="RESUMEN ECONÓMICO" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />

                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="Precio base de la ruta" FontSize="14" TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Column="1" x:Name="LabelPrecioBase" FontSize="14" TextColor="{StaticResource TextPrimary}" />
                            </Grid>

                            <BoxView HeightRequest="1" BackgroundColor="{StaticResource BorderColor}" Margin="0,4" />

                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="Monto pagado" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Column="1" x:Name="LabelMontoResumen" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource AccentBlue}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>

            </Grid>
        </ScrollView>

    </Grid>
</ContentPage>
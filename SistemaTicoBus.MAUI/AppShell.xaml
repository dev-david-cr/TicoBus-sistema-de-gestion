<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SistemaTicoBus.MAUI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:SistemaTicoBus.MAUI.Views"
    Shell.FlyoutBehavior="Disabled"
    BackgroundColor="#0D1117">

    <ShellContent
        ContentTemplate="{DataTemplate views:LoginPage}"
        Route="LoginPage" />

    <ShellContent
        ContentTemplate="{DataTemplate views:InicioPage}"
        Route="InicioPage" />

    <ShellContent
        ContentTemplate="{DataTemplate views:MisReservasPage}"
        Route="MisReservasPage" />

    <ShellContent
        ContentTemplate="{DataTemplate views:PerfilPage}"
        Route="PerfilPage" />

</Shell>
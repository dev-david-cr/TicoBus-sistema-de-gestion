@model List<SistemaTicoBus.MODEL.Entidades.Viaje>

@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    ViewData["Title"] = "Gestión de Viajes";
    ViewData["Seccion"] = "Viajes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <small class="text-muted text-uppercase fw-semibold">Operaciones / Trayectos</small>
        <h1 class="fw-bold text-dark mb-0">Gestión de Viajes</h1>
    </div>
    <button class="btn btn-primario d-flex align-items-center gap-2"
            data-bs-toggle="modal" data-bs-target="#modalAgregarViaje">
        <i class="bi bi-plus-circle"></i> Agregar Viaje
    </button>
</div>

<div class="dashboard-card mb-4">
    <form asp-action="Index" method="get">
        <div class="row align-items-center g-2">
            <div class="col-md-10">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-0 text-muted">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text"
                           name="filtro"
                           class="form-control border-0 bg-transparent"
                           placeholder="Buscar por ruta o fecha (dd/mm/aaaa)..."
                           value="@ViewBag.Filtro" />
                </div>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-secundario w-100">Buscar</button>
            </div>
        </div>
    </form>
</div>

<div class="dashboard-card">
    <h5 class="fw-bold text-dark mb-4">Listado de Trayectos</h5>
    <div class="table-responsive">
        <table class="table tabla-dashboard align-middle mb-0">
            <thead>
                <tr>
                    <th class="border-0 py-3">No. Viaje</th>
                    <th class="border-0 py-3">Ruta</th>
                    <th class="border-0 py-3">Placa Unidad</th>
                    <th class="border-0 py-3">Chofer</th>
                    <th class="border-0 py-3">Fecha de Salida</th>
                    <th class="border-0 py-3">Estado</th>
                    <th class="border-0 py-3 text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var viaje in Model)
                    {
                        <tr>
                            <td class="fw-bold text-dark">#V-@viaje.IdViaje</td>
                            <td>@viaje.Ruta?.Nombre</td>
                            <td>@viaje.PlacaUnidad</td>
                            <td>@viaje.Chofer?.Nombre</td>
                            <td>@viaje.FechaHoraSalida.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @switch (viaje.Estado)
                                {
                                    case "Programado":
                                        <span class="badge-programado">● Programado</span>
                                        break;
                                    case "En Curso":
                                        <span class="badge-en-curso">● En Curso</span>
                                        break;
                                    case "Completado":
                                        <span class="badge-completado">● Completado</span>
                                        break;
                                    case "Cancelado":
                                        <span class="badge-cancelado">● Cancelado</span>
                                        break;
                                }
                            </td>
                            <td class="text-end">
                                @if (viaje.Estado == "Programado")
                                {
                                    <button type="button"
                                            class="btn btn-sm btn-outline-warning border-0"
                                            title="Editar"
                                            onclick="prepararEdicion(
                                        @viaje.IdViaje,
                                        @viaje.IdRuta,
                                        '@viaje.PlacaUnidad',
                                        '@viaje.ChoferId',
                                        '@viaje.FechaHoraSalida.ToString("yyyy-MM-ddTHH:mm")',
                                        '@viaje.FechaHoraLlegadaEstimada.ToString("yyyy-MM-ddTHH:mm")')">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>

                                    
                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger border-0"
                                            title="Cancelar viaje"
                                            onclick="prepararCancelacion(@viaje.IdViaje)">
                                        <i class="bi bi-x-circle"></i>
                                    </button>

                                    <form asp-action="Iniciar" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="idViaje" value="@viaje.IdViaje" />
                                        <button type="submit"
                                                class="btn btn-sm btn-outline-success border-0"
                                                title="Iniciar viaje"
                                                onclick="return confirm('¿Confirma que desea iniciar el viaje #@viaje.IdViaje?')">
                                            <i class="bi bi-play-circle"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted">
                            No se encontraron viajes que coincidan con la búsqueda.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="modalAgregarViaje" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" style="border-radius: 1rem;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Agregar Nuevo Viaje</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form asp-action="Agregar" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Ruta</label>
                            <select name="IdRuta" class="form-select" required>
                                <option value="">Seleccione una ruta...</option>
                                @foreach (var item in ViewBag.Rutas as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Unidad</label>
                            <select name="PlacaUnidad" class="form-select" required>
                                <option value="">Seleccione una unidad...</option>
                                @foreach (var item in ViewBag.Unidades as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Chofer</label>
                            <select name="ChoferId" class="form-select" required>
                                <option value="">Seleccione un chofer...</option>
                                @foreach (var item in ViewBag.Choferes as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Fecha y Hora de Salida</label>
                            <input type="datetime-local" name="FechaHoraSalida" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Fecha y Hora Estimada de Llegada</label>
                            <input type="datetime-local" name="FechaHoraLlegadaEstimada" class="form-control" required />
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primario">Registrar Viaje</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalEditarViaje" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" style="border-radius: 1rem;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Editar Viaje</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form asp-action="Editar" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="editIdViaje" name="IdViaje" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Ruta</label>
                            <select id="editRuta" name="IdRuta" class="form-select" required>
                                @foreach (var item in ViewBag.Rutas as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Unidad</label>
                            <select id="editUnidad" name="PlacaUnidad" class="form-select" required>
                                @foreach (var item in ViewBag.Unidades as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Chofer</label>
                            <select id="editChofer" name="ChoferId" class="form-select" required>
                                @foreach (var item in ViewBag.Choferes as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Fecha y Hora de Salida</label>
                            <input type="datetime-local" id="editSalida" name="FechaHoraSalida" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Fecha y Hora Estimada de Llegada</label>
                            <input type="datetime-local" id="editLlegada" name="FechaHoraLlegadaEstimada" class="form-control" required />
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primario">Guardar Cambios</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalCancelarViaje" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius: 1rem;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-danger">Cancelar Viaje</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form asp-action="Cancelar" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="cancelIdViaje" name="idViaje" />
                    <div class="mb-3">
                        <label class="form-label">Motivo de cancelación</label>
                        <textarea name="motivo"
                                  class="form-control"
                                  rows="3"
                                  placeholder="Ingrese el motivo de cancelación..."
                                  required></textarea>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Volver</button>
                        <button type="submit" class="btn btn-danger">Confirmar Cancelación</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function prepararEdicion(id, rutaId, placa, choferId, salida, llegada) {
            document.getElementById('editIdViaje').value = id;
            document.getElementById('editRuta').value = rutaId;
            document.getElementById('editUnidad').value = placa;
            document.getElementById('editChofer').value = choferId;
            document.getElementById('editSalida').value = salida;
            document.getElementById('editLlegada').value = llegada;
            new bootstrap.Modal(document.getElementById('modalEditarViaje')).show();
        }

        function prepararCancelacion(id) {
            document.getElementById('cancelIdViaje').value = id;
            new bootstrap.Modal(document.getElementById('modalCancelarViaje')).show();
        }
    </script>
}
@using System
@using Microsoft.AspNetCore.Http

@{
    string nombreUsuario = Context.Session.GetString("NombreUsuario") ?? string.Empty;
    string rol = Context.Session.GetString("Rol") ?? string.Empty;
    string tituloPortal = string.Equals(rol, "Pasajero", StringComparison.OrdinalIgnoreCase)
        ? "Portal del Pasajero"
        : "Consola de Operador";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TicoBus</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/dashboard.css" />

    <style>
            html {
                font-size: 15px;
            }

            body {
                margin: 0;
                background-color: #f4f6f8;
                font-family: 'Montserrat', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                color: #111827;
                font-size: 0.95rem;
            }

            .app-shell {
                min-height: 100vh;
                display: flex;
                background-color: #f4f6f8;
            }

            .sidebar-ticobus {
                width: 280px;
                min-width: 280px;
                min-height: 100vh;
                background: #ffffff;
                border-right: 1px solid #e5e7eb;
                box-shadow: 0 1px 3px rgba(15, 23, 42, 0.08);
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                padding: 20px 12px;
            }

            .sidebar-brand {
                padding: 0 12px;
                margin-bottom: 26px;
            }

            .sidebar-brand-row {
                display: flex;
                align-items: center;
                gap: 9px;
            }

            .sidebar-brand-icon {
                font-size: 31px;
                color: #006a62;
                font-weight: 700;
            }

            .sidebar-brand-title {
                margin: 0;
                color: #111827;
                font-size: 24px;
                font-weight: 800;
                line-height: 1;
            }

            .sidebar-brand-subtitle {
                margin-top: 4px;
                color: #6b7280;
                font-size: 13px;
                font-weight: 400;
            }

            .sidebar-section-title {
                padding: 0 10px;
                margin-bottom: 12px;
                color: #9ca3af;
                font-size: 12px;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: 0.05em;
            }

            .sidebar-nav {
                display: flex;
                flex-direction: column;
                gap: 7px;
            }

            .sidebar-link {
                display: flex;
                align-items: center;
                gap: 14px;
                width: 100%;
                padding: 11px 14px;
                border-radius: 8px;
                color: #4b5563;
                text-decoration: none;
                font-size: 15px;
                font-weight: 500;
                transition: background-color 0.18s ease, color 0.18s ease;
            }

                .sidebar-link:hover {
                    background: #f3f4f6;
                    color: #111827;
                    text-decoration: none;
                }

            .sidebar-link-active {
                background: #e0f2f1;
                color: #004d40;
                font-weight: 800;
            }

            .sidebar-icon {
                font-size: 24px;
                color: #64748b;
                font-variation-settings: 'FILL' 0, 'wght' 400;
            }

            .sidebar-icon-active {
                color: #006a62;
                font-variation-settings: 'FILL' 0, 'wght' 600;
            }

            .sidebar-logout-box {
                border-top: 1px solid #e5e7eb;
                padding-top: 14px;
                margin-top: 20px;
            }

            .sidebar-logout-link {
                display: flex;
                align-items: center;
                gap: 14px;
                padding: 10px 14px;
                border-radius: 8px;
                color: #dc2626;
                text-decoration: none;
                font-size: 14px;
                font-weight: 600;
            }

                .sidebar-logout-link:hover {
                    background: #fef2f2;
                    color: #b91c1c;
                    text-decoration: none;
                }

            .app-main-wrapper {
                flex-grow: 1;
                min-width: 0;
                display: flex;
                flex-direction: column;
            }

            .app-header {
                min-height: 56px;
                background: #0f172a;
                color: white;
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0 24px;
                box-shadow: 0 2px 4px rgba(15, 23, 42, 0.20);
            }

            .app-content {
                flex-grow: 1;
                min-width: 0;
                overflow: auto;
                padding: 22px;
            }

                .app-content h1,
                .app-content h2 {
                    font-size: 1.75rem;
                }

                .app-content h3 {
                    font-size: 1.35rem;
                }

                .app-content h4 {
                    font-size: 1.15rem;
                }

                .app-content h5 {
                    font-size: 1rem;
                }

                .app-content .card {
                    border-radius: 0.85rem !important;
                }

                .app-content .card-body {
                    padding: 1.15rem;
                }

                .app-content .form-control,
                .app-content .form-select,
                .app-content .btn {
                    font-size: 0.9rem;
                }

                .app-content .table {
                    font-size: 0.9rem;
                }

                    .app-content .table th,
                    .app-content .table td {
                        padding-top: 0.75rem;
                        padding-bottom: 0.75rem;
                    }

                .app-content .material-symbols-outlined {
                    font-size: 22px;
                }

            @@media (max-width: 768px) {
                .sidebar-ticobus {
                    display: none;
                }

                .app-content {
                    padding: 16px;
                }
            }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <div class="app-shell">
        @await Html.PartialAsync("_DashboardSidebar", ViewData["Seccion"]?.ToString())

        <div class="app-main-wrapper">
            <header class="app-header">
                <div>
                    <span class="fw-bold">TicoBus</span>
                    <span class="mx-2 text-secondary">|</span>
                    <span class="text-uppercase text-white-50" style="font-size:0.72rem; letter-spacing:.05em;">
                        @tituloPortal
                    </span>
                </div>

                <div class="dropdown">
                    <button class="btn btn-link text-white text-decoration-none dropdown-toggle p-0 d-flex align-items-center"
                            type="button"
                            data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle me-2"></i>
                        <span>@nombreUsuario</span>
                    </button>

                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <a class="dropdown-item text-danger" href="/Account/Logout">
                                <i class="bi bi-box-arrow-right me-2"></i> Cerrar Sesión
                            </a>
                        </li>
                    </ul>
                </div>
            </header>

            <main class="app-content">
                @{
                    string mensajeExito = Convert.ToString(TempData["MensajeExito"] ?? TempData["Exito"]) ?? string.Empty;
                    string mensajeError = Convert.ToString(TempData["MensajeError"] ?? TempData["Error"]) ?? string.Empty;
                }

                @if (!string.IsNullOrWhiteSpace(mensajeExito))
                {
                    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                        <i class="bi bi-check-circle me-2"></i> @mensajeExito
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(mensajeError))
                {
                    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i> @mensajeError
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
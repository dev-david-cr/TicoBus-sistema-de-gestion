@model List<SistemaTicoBus.MODEL.Entidades.Reserva>
@using Microsoft.AspNetCore.Http
@{
    Layout = null;
    string nombreUsuario = Context.Session.GetString("NombreUsuario") ?? "pasajero";
    string tabActiva = ViewBag.Tab as string ?? "viajes";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Portal Pasajero - TicoBus</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
            body {
                background: #f4f6f8;
                font-family: 'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;
                font-size: 0.875rem;
            }

            .top-header {
                background: #112233;
                color: white;
                padding: 0.65rem 1.5rem;
            }

            .sidebar {
                background: #fff;
                min-height: 100vh;
                border-right: 1px solid #e9ecef;
            }

            .brand-title {
                color: #1a2530;
                font-size: 1.2rem;
                font-weight: 700;
            }

            .section-title {
                font-size: 0.7rem;
                text-transform: uppercase;
                letter-spacing: .05em;
                color: #9097a3;
                font-weight: 700;
            }

            .sidebar .nav-link {
                color: #5a6578;
                font-weight: 500;
                font-size: 0.82rem;
                padding: 0.65rem 1rem;
                border-radius: 0.5rem;
                margin-bottom: 0.2rem;
                display: flex;
                align-items: center;
                text-decoration: none;
            }

                .sidebar .nav-link.active {
                    background: #e0f2f1;
                    color: #004d40;
                    font-weight: 600;
                }

                .sidebar .nav-link:hover:not(.active) {
                    background: #f8f9fa;
                    color: #1a2530;
                }

            .dash-card {
                background: #fff;
                border-radius: 0.85rem;
                border: 1px solid #e9ecef;
                padding: 1.25rem;
                margin-bottom: 0.85rem;
            }

            .dash-card-dark {
                background: #06142d;
                color: white;
                border-radius: 0.85rem;
                padding: 1.25rem;
                margin-bottom: 0.85rem;
            }

            .perfil-hero {
                background: linear-gradient(135deg,#0f3460 0%,#112233 100%);
                color: white;
                border-radius: 0.85rem;
                padding: 1.5rem;
                margin-bottom: 1rem;
            }

            .avatar-circle {
                width: 56px;
                height: 56px;
                background: rgba(255,255,255,0.15);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.5rem;
                flex-shrink: 0;
            }

            .rol-badge {
                background: #59e3d8;
                color: #083344;
                font-size: 0.68rem;
                font-weight: 700;
                padding: 2px 10px;
                border-radius: 20px;
                display: inline-block;
                margin-top: 4px;
            }

            .estado-badge {
                padding: 4px 14px;
                border-radius: 50px;
                font-weight: 700;
                font-size: 0.72rem;
                display: inline-block;
            }

            .estado-en-curso {
                background: #59e3d8;
                color: #083344;
            }

            .estado-pendiente {
                background: #fef3c7;
                color: #92400e;
            }

            .estado-cancelado {
                background: #fee2e2;
                color: #991b1b;
            }

            .estado-programado {
                background: #e0e7ff;
                color: #3730a3;
            }

            .info-label {
                color: #6c757d;
                font-size: 0.68rem;
                text-transform: uppercase;
                font-weight: 700;
                letter-spacing: .04em;
                margin-bottom: 2px;
            }

            .info-value {
                font-weight: 600;
                font-size: 0.85rem;
                color: #1a2530;
            }

            .total-pago {
                color: #59e3d8;
                font-size: 1.4rem;
                font-weight: 700;
            }

            h5.section-heading {
                font-size: 0.9rem;
                font-weight: 700;
                color: #1a2530;
                margin-bottom: 0.75rem;
            }

            .detalle-viaje {
                background: #f8fafc;
                border: 1px solid #e2e8f0;
                border-radius: 0.65rem;
                padding: 0.85rem 1rem;
                margin-top: 0.5rem;
            }

            .det-label {
                font-size: 0.65rem;
                text-transform: uppercase;
                font-weight: 700;
                color: #94a3b8;
                margin-bottom: 2px;
            }

            .det-val {
                font-weight: 600;
                color: #1e293b;
                font-size: 0.82rem;
            }

            .clave-card {
                background: #fff;
                border-radius: 0.85rem;
                border: 1px solid #e9ecef;
                padding: 2rem;
                max-width: 420px;
                margin: 0 auto;
                box-shadow: 0 4px 20px rgba(0,0,0,0.06);
            }

            .icon-circle-lg {
                width: 56px;
                height: 56px;
                background: linear-gradient(135deg,#006a62,#004d40);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 0.75rem;
                color: white;
                font-size: 1.4rem;
            }

            .form-label {
                font-size: 0.72rem;
                font-weight: 700;
                color: #6c757d;
                text-transform: uppercase;
                letter-spacing: .04em;
            }

            .form-control {
                font-size: 0.82rem;
                border-radius: 0.45rem;
            }

                .form-control:focus {
                    border-color: #006a62;
                    box-shadow: 0 0 0 3px rgba(0,106,98,0.12);
                }

                .form-control[readonly] {
                    background: #f1f5f9;
                    color: #475569;
                    cursor: not-allowed;
                }

            .btn-ticobus {
                background: #006a62;
                color: white;
                font-weight: 700;
                font-size: 0.85rem;
                border-radius: 0.5rem;
                padding: 0.7rem;
                border: none;
                width: 100%;
                transition: background .2s;
            }

                .btn-ticobus:hover {
                    background: #004d40;
                    color: white;
                }

            .perfil-dato {
                background: #f8fafc;
                border-radius: 0.5rem;
                padding: 0.75rem 1rem;
            }

            .pd-label {
                font-size: 0.65rem;
                text-transform: uppercase;
                font-weight: 700;
                color: #94a3b8;
                margin-bottom: 2px;
            }

            .pd-val {
                font-weight: 600;
                color: #1e293b;
                font-size: 0.85rem;
            }
    </style>
</head>
<body>
    <div class="container-fluid p-0">

        <div class="row g-0 top-header align-items-center">
            <div class="col-6 d-flex align-items-center gap-2">
                <span class="fw-bold" style="font-size:1rem;">TicoBus</span>
                <span class="text-secondary">|</span>
                <span class="text-muted text-uppercase" style="font-size:0.68rem;letter-spacing:.05em;">Portal Pasajero</span>
            </div>
            <div class="col-6 text-end">
                <div class="dropdown d-inline-block">
                    <button class="btn btn-link text-white text-decoration-none dropdown-toggle p-0 d-flex align-items-center ms-auto"
                            style="font-size:0.82rem;" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle me-2" style="font-size:1.1rem;"></i>@nombreUsuario
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item text-danger" href="/Account/Logout"><i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesión</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="row g-0">
            <div class="col-md-3 col-lg-2 p-3 sidebar d-none d-md-flex flex-column justify-content-between">
                <div>
                    <div class="mb-4 px-2">
                        <h2 class="brand-title m-0">TicoBus</h2>
                        <span class="text-muted" style="font-size:0.72rem;">Portal del Pasajero</span>
                    </div>
                    <div class="mb-2 px-2"><span class="section-title">Mi Cuenta</span></div>
                    <ul class="nav flex-column mb-4">
                        <li><a href="?tab=perfil" class="nav-link @(tabActiva == "perfil" ? "active" : "")"><i class="bi bi-person me-3"></i>Mi Perfil</a></li>
                        <li><a href="?tab=viajes" class="nav-link @(tabActiva == "viajes" ? "active" : "")"><i class="bi bi-ticket-perforated me-3"></i>Mis Viajes</a></li>
                        <li><a href="?tab=clave" class="nav-link @(tabActiva == "clave" ? "active" : "")"><i class="bi bi-lock me-3"></i>Cambiar Clave</a></li>
                    </ul>
                </div>
                <div>
                    <hr class="text-muted">
                    <ul class="nav flex-column">
                        <li><a href="/Account/Logout" class="nav-link text-danger"><i class="bi bi-box-arrow-right me-3"></i>Cerrar Sesión</a></li>
                    </ul>
                </div>
            </div>

            <div class="col-md-9 col-lg-10 p-4">

                @if (TempData["MensajeExito"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show py-2 mb-3" style="font-size:0.82rem;" role="alert">
                        <i class="bi bi-check-circle me-2"></i>@TempData["MensajeExito"]
                        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
                    </div>
                }

                @if (tabActiva == "perfil")
                {
                    <div class="text-uppercase fw-bold mb-3" style="font-size:0.68rem;color:#9097a3;letter-spacing:.08em;">PASAJERO ➔ MI PERFIL</div>
                    <div class="perfil-hero">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="avatar-circle"><i class="bi bi-person-fill"></i></div>
                            <div>
                                <div class="fw-bold" style="font-size:1.05rem;">@nombreUsuario</div>
                                <span class="rol-badge">Pasajero</span>
                            </div>
                        </div>
                        <div class="row g-2 border-top border-white border-opacity-25 pt-3">
                            <div class="col-6">
                                <div style="font-size:0.65rem;color:rgba(255,255,255,0.6);text-transform:uppercase;font-weight:700;">Usuario</div>
                                <div style="font-size:0.85rem;font-weight:600;">@nombreUsuario</div>
                            </div>
                            <div class="col-6">
                                <div style="font-size:0.65rem;color:rgba(255,255,255,0.6);text-transform:uppercase;font-weight:700;">Total Reservas</div>
                                <div style="font-size:0.85rem;font-weight:600;">@(Model?.Count ?? 0) viaje(s)</div>
                            </div>
                        </div>
                    </div>
                    <div class="dash-card">
                        <h5 class="section-heading"><i class="bi bi-info-circle me-2 text-primary"></i>Información de la cuenta</h5>
                        <div class="row g-3">
                            <div class="col-md-4"><div class="perfil-dato"><div class="pd-label">Nombre de usuario</div><div class="pd-val">@nombreUsuario</div></div></div>
                            <div class="col-md-4"><div class="perfil-dato"><div class="pd-label">Rol</div><div class="pd-val">Pasajero</div></div></div>
                            <div class="col-md-4"><div class="perfil-dato"><div class="pd-label">Reservas activas</div><div class="pd-val">@(Model?.Count(r => r.Viaje?.Estado?.ToLower() != "cancelado") ?? 0)</div></div></div>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <a href="?tab=viajes" class="btn btn-sm btn-outline-primary" style="font-size:0.78rem;border-radius:0.45rem;"><i class="bi bi-ticket-perforated me-1"></i>Ver mis viajes</a>
                        <a href="?tab=clave" class="btn btn-sm btn-outline-secondary" style="font-size:0.78rem;border-radius:0.45rem;"><i class="bi bi-lock me-1"></i>Cambiar clave</a>
                    </div>
                }

                @if (tabActiva == "viajes")
                {
                    <div class="text-uppercase fw-bold mb-3" style="font-size:0.68rem;color:#9097a3;letter-spacing:.08em;">PASAJERO ➔ MIS VIAJES</div>

                    @if (Model != null && Model.Any())
                    {
                        var actual = Model.First();
                        string ec = actual.Viaje?.Estado?.ToLower() switch
                        {
                            "cancelado" => "estado-cancelado",
                            "pendiente" => "estado-pendiente",
                            "programado" => "estado-programado",
                            _ => "estado-en-curso"
                        };

                        <h5 class="section-heading"><i class="bi bi-geo-alt-fill me-2 text-success"></i>Mi Viaje Actual</h5>
                        <div class="dash-card">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <div class="info-label">Ruta</div>
                                    <div class="fw-bold" style="font-size:1rem;color:#1a2530;">@actual.Viaje?.Ruta?.Nombre</div>
                                </div>
                                <span class="estado-badge @ec">@actual.Viaje?.Estado</span>
                            </div>
                            <div class="row g-3 mb-3">
                                <div class="col-6 col-md-3"><div class="info-label">Asiento</div><div class="info-value">@actual.NumeroAsiento</div></div>
                                <div class="col-6 col-md-3"><div class="info-label">Salida</div><div class="info-value">@actual.Viaje?.FechaHoraSalida.ToString("dd/MM/yyyy HH:mm")</div></div>
                                <div class="col-6 col-md-3"><div class="info-label">Llegada est.</div><div class="info-value">@actual.Viaje?.FechaHoraLlegadaEstimada.ToString("dd/MM/yyyy HH:mm")</div></div>
                            </div>
                            <div class="detalle-viaje">
                                <div class="fw-bold mb-2" style="font-size:0.75rem;color:#64748b;"><i class="bi bi-info-circle me-1"></i>Detalle del viaje</div>
                                <div class="row g-2">
                                    <div class="col-6 col-md-3"><div class="det-label">Unidad (Placa)</div><div class="det-val">@actual.Viaje?.PlacaUnidad</div></div>
                                    <div class="col-6 col-md-3"><div class="det-label">Modelo</div><div class="det-val">@(actual.Viaje?.Unidad?.Modelo ?? "—")</div></div>
                                    <div class="col-6 col-md-3"><div class="det-label">Capacidad</div><div class="det-val">@(actual.Viaje?.Unidad?.CapacidadPasajeros.ToString() ?? "—") pas.</div></div>
                                    <div class="col-6 col-md-3"><div class="det-label">Chofer</div><div class="det-val">@(actual.Viaje?.Chofer != null ? $"{actual.Viaje.Chofer.Nombre} {actual.Viaje.Chofer.Apellidos}" : "—")</div></div>
                                </div>
                            </div>
                        </div>

                        <div class="dash-card-dark">
                            <div class="fw-bold mb-2" style="font-size:0.88rem;">Resumen de Pago</div>
                            <hr style="border-color:rgba(255,255,255,0.15);" />
                            <div class="d-flex justify-content-between mb-2" style="font-size:0.82rem;">
                                <span style="color:rgba(255,255,255,0.7);">Precio Base (ruta)</span>
                                <span>₡@actual.Viaje?.Ruta?.PrecioBase.ToString("N0")</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <strong style="font-size:0.82rem;">Total Abonado</strong>
                                <span class="total-pago">₡@actual.MontoPagado.ToString("N0")</span>
                            </div>
                        </div>

                        <h5 class="section-heading mt-2"><i class="bi bi-list-ul me-2 text-primary"></i>Todas mis Reservas</h5>
                        @foreach (var item in Model)
                        {
                            string ic = item.Viaje?.Estado?.ToLower() switch
                            {
                                "cancelado" => "estado-cancelado",
                                "pendiente" => "estado-pendiente",
                                "programado" => "estado-programado",
                                _ => "estado-en-curso"
                            };
                            <div class="dash-card">
                                <div class="row g-2 align-items-start">
                                    <div class="col-12 col-md-3"><div class="info-label">Ruta</div><div class="info-value">@item.Viaje?.Ruta?.Nombre</div></div>
                                    <div class="col-4 col-md-1"><div class="info-label">Estado</div><span class="estado-badge @ic" style="font-size:0.62rem;padding:2px 7px;">@item.Viaje?.Estado</span></div>
                                    <div class="col-4 col-md-1"><div class="info-label">Asiento</div><div class="info-value">@item.NumeroAsiento</div></div>
                                    <div class="col-4 col-md-2"><div class="info-label">Salida</div><div class="info-value">@item.Viaje?.FechaHoraSalida.ToString("dd/MM/yyyy HH:mm")</div></div>
                                    <div class="col-12 col-md-5">
                                        <div class="detalle-viaje py-2 px-3">
                                            <div class="row g-1">
                                                <div class="col-6"><div class="det-label">Unidad</div><div class="det-val">@item.Viaje?.PlacaUnidad @(item.Viaje?.Unidad?.Modelo != null ? "· " + item.Viaje.Unidad.Modelo : "")</div></div>
                                                <div class="col-6"><div class="det-label">Chofer</div><div class="det-val">@(item.Viaje?.Chofer != null ? $"{item.Viaje.Chofer.Nombre} {item.Viaje.Chofer.Apellidos}" : "—")</div></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="dash-card text-center py-5">
                            <i class="bi bi-ticket-perforated text-muted" style="font-size:2.5rem;"></i>
                            <p class="mt-3 text-muted fw-semibold" style="font-size:0.88rem;">No tienes reservas registradas aún.</p>
                        </div>
                    }
                }

                @if (tabActiva == "clave")
                {
                    <div class="text-uppercase fw-bold mb-4" style="font-size:0.68rem;color:#9097a3;letter-spacing:.08em;">PASAJERO ➔ CAMBIAR CLAVE</div>
                    <div class="clave-card">
                        <div class="text-center mb-3 pb-3 border-bottom">
                            <div class="icon-circle-lg"><i class="bi bi-shield-lock"></i></div>
                            <h5 class="fw-bold mb-1" style="color:#1a2530;font-size:1rem;">Cambio de Clave</h5>
                            <p class="text-muted mb-0" style="font-size:0.78rem;">Ingresa tu clave actual y la nueva clave</p>
                            <span style="display:inline-flex;align-items:center;gap:5px;background:#e0f2f1;color:#004d40;font-size:0.75rem;font-weight:700;padding:3px 12px;border-radius:20px;margin-top:8px;">
                                <i class="bi bi-person-fill"></i> @nombreUsuario
                            </span>
                        </div>
                        <form asp-controller="Account" asp-action="ChangePassword" method="post">
                            @Html.AntiForgeryToken()
                            <div class="mb-3"><label class="form-label">Usuario</label><input type="text" name="Nombre" class="form-control" value="@nombreUsuario" readonly /></div>
                            <div class="mb-3"><label class="form-label">Clave Actual</label><input type="password" name="ClaveActual" class="form-control" placeholder="Tu clave actual" autocomplete="current-password" required /></div>
                            <div class="mb-4"><label class="form-label">Nueva Clave</label><input type="password" name="NuevaClave" class="form-control" placeholder="Tu nueva clave" autocomplete="new-password" required /></div>
                            <button type="submit" class="btn btn-ticobus"><i class="bi bi-check-lg me-2"></i>Actualizar Clave</button>
                        </form>
                        <a href="?tab=viajes" class="d-block text-center mt-3" style="color:#006a62;font-size:0.82rem;font-weight:600;text-decoration:none;">← Volver a mis viajes</a>
                    </div>
                }

            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

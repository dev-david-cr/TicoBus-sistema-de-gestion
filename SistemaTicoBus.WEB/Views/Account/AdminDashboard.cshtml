@model SistemaTicoBus.WEB.Models.AdminDashboardViewModel
@using Microsoft.AspNetCore.Http

@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    ViewData["Title"] = "Catálogo de Rutas";
    ViewData["Seccion"] = "Rutas";
}

<!-- ENCABEZADO -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <small class="text-muted text-uppercase fw-semibold">Administración / Rutas</small>
        <h1 class="fw-bold text-dark mb-0">Catálogo de Rutas</h1>
    </div>
</div>

<!-- BUSCADOR -->
<div class="dashboard-card mb-4">
    <form asp-controller="Account" asp-action="AdminDashboard" method="get">
        <div class="row align-items-center g-2">
            <div class="col-md-10">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-0 text-muted">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text"
                           name="buscar"
                           class="form-control border-0 bg-transparent"
                           placeholder="Buscar rutas por nombre, origen o destino..."
                           value="@ViewBag.BusquedaActual" />
                </div>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-secundario w-100">Buscar</button>
            </div>
        </div>
    </form>
</div>

<!-- CONTENIDO PRINCIPAL -->
<div class="row g-4">

    @if (Context.Session.GetString("Rol") == "Administrador")
    {
        <!-- FORMULARIO AGREGAR / EDITAR -->
        <div class="col-xl-4 col-lg-5">
            <div class="dashboard-card shadow-sm">
                <h4 id="formTitle" class="fs-5 fw-bold mb-4 text-dark">Agregar Nueva Ruta</h4>
                <form id="formRuta" asp-controller="Rutas" asp-action="Crear" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="inputId" />
                    <div class="mb-3">
                        <label class="form-label">Nombre</label>
                        <input type="text" name="nombre" id="inputNombre" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Origen</label>
                        <input type="text" name="origen" id="inputOrigen" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Destino</label>
                        <input type="text" name="destino" id="inputDestino" class="form-control" required />
                    </div>
                    <div class="row g-2 mb-4">
                        <div class="col-6">
                            <label class="form-label">Duración (hh:mm)</label>
                            <input type="text" name="duracion" id="inputDuracion" class="form-control" placeholder="04:30" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label">Precio Base</label>
                            <input type="number"
                                   step="0.01"
                                   min="0.01"
                                   name="precioBase"
                                   id="inputPrecio"
                                   class="form-control"
                                   required />
                        </div>
                    </div>
                    <button type="submit" id="btnSubmit" class="btn btn-primario w-100">Registrar Ruta</button>
                </form>
            </div>
        </div>
    }

    <!-- TABLA DE RUTAS -->
    <div class="col-xl-8 col-lg-7">
        <div class="dashboard-card shadow-sm">
            <h4 class="fs-5 fw-bold mb-4 text-dark">Listado de Rutas</h4>
            <div class="table-responsive">
                <table class="table tabla-dashboard align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="border-0 py-3">ID / Nombre</th>
                            <th class="border-0 py-3">Origen</th>
                            <th class="border-0 py-3">Destino</th>
                            <th class="border-0 py-3">Duración</th>
                            <th class="border-0 py-3">Precio Base</th>
                            <th class="border-0 py-3 text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model?.Rutas != null && Model.Rutas.Any())
                        {
                            foreach (var ruta in Model.Rutas)
                            {
                                <tr>
                                    <td class="py-3">
                                        <span class="fw-bold text-dark">@ruta.Nombre</span>
                                    </td>
                                    <td class="text-secondary">@ruta.Origen</td>
                                    <td class="text-secondary">@ruta.Destino</td>
                                    <td>
                                        <span class="badge bg-light text-dark border px-2 py-1">
                                            <i class="bi bi-clock me-1 text-muted"></i>
                                            @ruta.DuracionEstimada.ToString(@"hh\:mm") h
                                        </span>
                                    </td>
                                    <td class="fw-bold text-success">@ruta.PrecioBase.ToString("C0")</td>
                                    <td class="text-end py-3">
                                        @if (Context.Session.GetString("Rol") == "Administrador")
                                        {
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-warning border-0"
                                                    title="Editar"
                                                    onclick="editarRuta(@ruta.Id, '@ruta.Nombre', '@ruta.Origen', '@ruta.Destino', '@ruta.DuracionEstimada.ToString(@"hh\:mm")', '@ruta.PrecioBase')">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                            <form asp-controller="Rutas" asp-action="EliminarRuta" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@ruta.Id" />
                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-danger border-0"
                                                        title="Eliminar"
                                                        onclick="return confirm('¿Seguro que deseas eliminar esta ruta?')">
                                                    <i class="bi bi-trash-fill"></i>
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">
                                    No se encontraron rutas que coincidan con la búsqueda.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function editarRuta(id, nombre, origen, destino, duracion, precio) {
            document.getElementById('formTitle').innerText = "Editar Ruta";
            document.getElementById('formRuta').action = "/Rutas/Editar";
            document.getElementById('inputId').value = id;
            document.getElementById('inputNombre').value = nombre;
            document.getElementById('inputOrigen').value = origen;
            document.getElementById('inputDestino').value = destino;
            document.getElementById('inputDuracion').value = duracion;
            document.getElementById('inputPrecio').value = precio;
            document.getElementById('btnSubmit').innerText = "Guardar Cambios";
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    </script>
}
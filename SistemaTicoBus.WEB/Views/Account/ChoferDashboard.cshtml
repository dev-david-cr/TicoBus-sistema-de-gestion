@model SistemaTicoBus.WEB.Models.ChoferDashboardViewModel

@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    ViewData["Title"] = "Perfil Chofer";
    ViewData["Seccion"] = "PerfilChofer";
}

<div class="mb-4">
    <div class="text-uppercase text-muted fw-bold" style="font-size:0.75rem; letter-spacing:.08em;">
        Chofer &gt; Mi Perfil
    </div>
    <h2 class="fw-bold mb-0 mt-2">Mi Perfil</h2>
</div>

<div class="row justify-content-center mb-4">
    <div class="col-xl-7 col-lg-8">
        <div class="card border-0 shadow-lg overflow-hidden" style="border-radius:1rem;">
            <div class="card-body p-4 text-white" style="background:linear-gradient(90deg,#1d4ed8,#1e3a8a);">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width:72px;height:72px;background:rgba(255,255,255,.18);">
                        <span class="material-symbols-outlined" style="font-size:44px;">account_box</span>
                    </div>

                    <div>
                        <h3 class="fw-bold mb-1">@Model.NombreCompleto</h3>
                        <span class="badge rounded-pill text-dark fw-bold" style="background:#2dd4bf;">
                            @Model.Rol
                        </span>
                    </div>
                </div>

                <div class="border-top border-white border-opacity-25 pt-3">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="text-uppercase fw-bold text-white-50" style="font-size:.7rem;">Identificación</div>
                            <div class="font-monospace fw-semibold">@Model.Identificacion</div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-uppercase fw-bold text-white-50" style="font-size:.7rem;">Terminal Base</div>
                            <div class="fw-semibold">Terminal Central 7-10</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mx-auto" style="max-width:1050px; border-radius:1rem;">
    <div class="card-header bg-white border-0 px-4 pt-4 pb-2">
        <h5 class="fw-bold mb-1">Viajes asignados</h5>
        <p class="text-muted small mb-0">Listado informativo según los viajes registrados para el chofer.</p>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-uppercase small text-muted">
                    <tr>
                        <th class="px-4 py-3">Viaje</th>
                        <th class="px-4 py-3">Ruta</th>
                        <th class="px-4 py-3">Unidad</th>
                        <th class="px-4 py-3">Salida</th>
                        <th class="px-4 py-3">Ocupación</th>
                        <th class="px-4 py-3">Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Viajes != null && Model.Viajes.Any())
                    {
                        foreach (var viaje in Model.Viajes)
                        {
                            <tr>
                                <td class="px-4 py-3 fw-bold">@viaje.IdViaje</td>
                                <td class="px-4 py-3">@viaje.Ruta</td>
                                <td class="px-4 py-3">@viaje.UnidadPlaca</td>
                                <td class="px-4 py-3">@viaje.HorarioSalida</td>
                                <td class="px-4 py-3">@viaje.Ocupacion</td>
                                <td class="px-4 py-3">
                                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle">
                                        @viaje.Estado
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="px-4 py-5 text-center text-muted">
                                <i class="bi bi-info-circle fs-4 d-block mb-2"></i>
                                No hay viajes asignados para este chofer.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
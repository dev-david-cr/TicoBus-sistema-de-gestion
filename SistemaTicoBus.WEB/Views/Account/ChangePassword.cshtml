@model SistemaTicoBus.WEB.Models.ChangePasswordViewModel
@using System
@using Microsoft.AspNetCore.Http

@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    ViewData["Title"] = "Cambio de Clave";
    ViewData["Seccion"] = "CambiarClave";

    string nombreUsuario = Context.Session.GetString("NombreUsuario") ?? string.Empty;
    string rol = Context.Session.GetString("Rol") ?? string.Empty;
    string urlVolver = string.Equals(rol, "Chofer", StringComparison.OrdinalIgnoreCase) ? "/Account/ChoferDashboard"
                     : string.Equals(rol, "Pasajero", StringComparison.OrdinalIgnoreCase) ? "/Account/PasajeroDashboard"
                     : "/Account/AdminDashboard";
}

<div class="row justify-content-center">
    <div class="col-xl-5 col-lg-6 col-md-8">
        <div class="card border-0 shadow-sm" style="border-radius:1rem; overflow:hidden;">
            <div class="card-header bg-white border-0 text-center px-4 pt-4 pb-2">
                <div class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle"
                     style="width:64px;height:64px;background:#e0f2f1;color:#006a62;">
                    <i class="bi bi-shield-lock fs-3"></i>
                </div>
                <h4 class="fw-bold mb-1">Cambio de Clave</h4>
                <p class="text-muted small mb-2">Ingresa tu clave actual y la nueva clave.</p>
                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">
                    <i class="bi bi-person-fill me-1"></i> @nombreUsuario
                </span>
            </div>

            <div class="card-body p-4">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2 mb-3" style="font-size:0.85rem;">
                        <div asp-validation-summary="ModelOnly"></div>
                    </div>
                }

                <form asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label fw-bold small text-uppercase text-muted">Usuario</label>
                        <input asp-for="Nombre" class="form-control" readonly />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ClaveActual" class="form-label fw-bold small text-uppercase text-muted">Clave Actual</label>
                        <input asp-for="ClaveActual"
                               type="password"
                               class="form-control"
                               placeholder="Tu clave actual"
                               autocomplete="current-password" />
                        <span asp-validation-for="ClaveActual" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="NuevaClave" class="form-label fw-bold small text-uppercase text-muted">Nueva Clave</label>
                        <input asp-for="NuevaClave"
                               type="password"
                               class="form-control"
                               placeholder="Tu nueva clave"
                               autocomplete="new-password" />
                        <span asp-validation-for="NuevaClave" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-success w-100 fw-bold py-2">
                        <i class="bi bi-check-lg me-2"></i>Actualizar Clave
                    </button>
                </form>

                <div class="text-center mt-3">
                    <a href="@urlVolver" class="text-success fw-bold text-decoration-none small">
                        ← Volver al panel
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
}
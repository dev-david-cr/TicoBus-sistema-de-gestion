@model SistemaTicoBus.WEB.Models.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar Sesión - TicoBus</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
            body {
                margin: 0;
                padding: 0;
                height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
                background-color: #d1d5db;
                position: relative;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                overflow: hidden;
            }

                body::before {
                    content: "";
                    position: absolute;
                    top: 0;
                    left: 0;
                    width: 100%;
                    height: 100%;
                    background-image: url('/images/fondo-bus.jpg');
                    background-size: cover;
                    background-position: center;
                    opacity: 0.15;
                    z-index: 1;
                }

            .login-card {
                position: relative;
                z-index: 5;
                background: #ffffff;
                padding: 40px;
                border-radius: 16px;
                box-shadow: 0 10px 30px rgba(0,0,0,0.1);
                width: 100%;
                max-width: 420px;
                text-align: center;
            }

            .logo-container-central {
                display: flex;
                justify-content: center;
                margin-bottom: 8px;
            }

                .logo-container-central img {
                    width: 100%;
                    max-width: 265px;
                    height: auto;
                    object-fit: contain;
                }

            .btn-login {
                background-color: #474f5e;
                color: white;
                width: 100%;
                padding: 12px;
                border: none;
                border-radius: 6px;
                font-weight: bold;
                transition: background 0.2s;
            }

                .btn-login:hover {
                    background-color: #353b47;
                    color: white;
                }

            .password-container {
                position: relative;
            }

            .toggle-password {
                position: absolute;
                right: 12px;
                top: 50%;
                transform: translateY(-50%);
                cursor: pointer;
                color: #6c757d;
            }
    </style>
</head>
<body>

    <div class="login-card">

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger py-2 small text-start" role="alert">
                <div asp-validation-summary="ModelOnly"></div>
            </div>
        }

        <div class="logo-container-central">
            <img src="/images/logo-ticobus.png?v=4" alt="TicoBus Logo">
        </div>

        <p class="text-muted small mb-4" style="font-size: 13px;">Gestión de Transporte</p>

        <form asp-action="Login" method="post">
            <div class="mb-3 text-start">
                <label class="form-label small fw-bold text-muted mb-1">USUARIO</label>
                <input asp-for="Username" class="form-control" placeholder="ejemplo_usuario" autocomplete="off" />
                <span asp-validation-for="Username" class="text-danger small"></span>
            </div>

            <div class="mb-4 text-start">
                <div class="d-flex justify-content-between">
                    <label class="form-label small fw-bold text-muted mb-1">CONTRASEÑA</label>
                    <a href="#" class="small fw-bold text-success text-decoration-none">¿Olvidó la contraseña?</a>
                </div>
                <div class="password-container">
                    <input asp-for="Password" id="txtPassword" type="password" class="form-control" placeholder="••••••••" />
                    <i class="fa-solid fa-eye toggle-password" id="btnTogglePassword"></i>
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-login mb-3">
                <i class="fa-solid fa-right-to-bracket me-2"></i>Iniciar Sesión
            </button>
        </form>

        <p class="text-muted text-center m-0" style="font-size: 11px;">
            Acceso seguro exclusivo para personal autorizado.
        </p>
    </div>

    <script>
            const btnToggle = document.getElementById('btnTogglePassword');
            const txtPassword = document.getElementById('txtPassword');

            btnToggle.addEventListener('click', function () {
                const type = txtPassword.getAttribute('type') === 'password' ? 'text' : 'password';
                txtPassword.setAttribute('type', type);

                this.classList.toggle('fa-eye');
                this.classList.toggle('fa-eye-slash');
            });
    </script>
</body>
</html>
@model IEnumerable<SistemaTicoBus.MODEL.Entidades.Viaje>

@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    ViewData["Title"] = "Viajes en Curso";
    ViewData["Seccion"] = "ViajesEnCurso";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <div class="text-uppercase text-muted fw-bold" style="font-size:0.75rem; letter-spacing:.08em;">
            Operación &gt; Viajes en Curso
        </div>
        <h2 class="fw-bold mb-0 mt-2">
            <i class="bi bi-bus-front text-primary me-2"></i>Monitoreo de Viajes en Curso
        </h2>
    </div>
    <span class="badge bg-success p-2 fs-6">Operaciones en Tiempo Real</span>
</div>

<div class="card shadow-sm border-0" style="border-radius:1rem; overflow:hidden;">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="px-4 py-3"># Viaje</th>
                    <th class="px-4 py-3">Ruta Destino</th>
                    <th class="px-4 py-3">Placa Unidad</th>
                    <th class="px-4 py-3">Salida</th>
                    <th class="px-4 py-3">Ocupación de la Unidad</th>
                    <th class="px-4 py-3 text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var viaje in Model)
                    {
                        int ocupados = viaje.Reservas?.Count ?? 0;
                        int capacidad = viaje.Unidad?.CapacidadPasajeros ?? 0;

                        <tr>
                            <td class="px-4 py-3 fw-bold text-primary">@viaje.IdViaje</td>
                            <td class="px-4 py-3">
                                <div class="fw-semibold">@viaje.Ruta?.Nombre</div>
                                <small class="text-muted">@viaje.Ruta?.Origen → @viaje.Ruta?.Destino</small>
                            </td>
                            <td class="px-4 py-3">
                                <span class="badge bg-dark">@viaje.PlacaUnidad</span>
                            </td>
                            <td class="px-4 py-3">@viaje.FechaHoraSalida.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="px-4 py-3">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height:8px; min-width:100px;">
                                        <div class="progress-bar bg-success"
                                             role="progressbar"
                                             style="width:@(capacidad > 0 ? (ocupados * 100 / capacidad) : 0)%">
                                        </div>
                                    </div>
                                    <div class="small fw-bold">
                                        @ocupados / @capacidad Asientos
                                    </div>
                                </div>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <a asp-action="Detalles" asp-route-id="@viaje.IdViaje" class="btn btn-primary btn-sm rounded fw-bold">
                                    <i class="bi bi-gear-fill me-1"></i> Panel de Control
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-5">
                            <i class="bi bi-info-circle fs-3 d-block mb-2"></i>
                            No se registran viajes con estado "En Curso" en este momento.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
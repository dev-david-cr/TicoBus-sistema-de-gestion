@model SistemaTicoBus.MODEL.Entidades.Viaje

@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    ViewData["Title"] = "Panel de Control de Viaje";
    ViewData["Seccion"] = "ViajesEnCurso";
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm fw-bold">
        <i class="bi bi-arrow-left me-1"></i> Volver al Monitoreo
    </a>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-primary shadow-sm h-100" style="border-radius:1rem; overflow:hidden;">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="card-title mb-0 fw-bold">
                    <i class="bi bi-calculator me-2"></i>Estado Financiero
                </h5>
            </div>
            <div class="card-body d-flex flex-column justify-content-between">
                <div>
                    <div class="mb-3">
                        <label class="text-muted small d-block">Pasajeros a Bordo</label>
                        <span class="fs-4 fw-bold text-dark">@ViewBag.PasajerosEmbarcados</span>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted small d-block">Asientos Disponibles</label>
                        <span class="fs-4 fw-bold text-success">@ViewBag.AsientosDisponibles</span>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted small d-block">Total Recaudado</label>
                        <span class="fs-3 fw-bold text-primary">₡@String.Format("{0:N2}", ViewBag.TotalRecaudado)</span>
                    </div>
                </div>

                <div class="d-grid gap-2 mt-3">
                    <a asp-action="Reservar" asp-route-id="@Model.IdViaje" class="btn btn-success fw-bold">
                        <i class="bi bi-plus-circle-fill me-1"></i> Reservar Asiento
                    </a>
                    <a asp-action="Finalizar" asp-route-id="@Model.IdViaje" class="btn btn-warning fw-bold">
                        <i class="bi bi-check2-circle me-1"></i> Finalizar Viaje
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card shadow-sm border-0 mb-4" style="border-radius:1rem; overflow:hidden;">
            <div class="card-header bg-white py-3">
                <h5 class="card-title mb-0 fw-bold">
                    <i class="bi bi-info-circle me-2 text-primary"></i>Información del Viaje #@Model.IdViaje
                </h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="text-muted small d-block">Ruta</label>
                        <div class="fw-bold">@Model.Ruta?.Nombre</div>
                        <div class="small text-muted">@Model.Ruta?.Origen → @Model.Ruta?.Destino</div>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small d-block">Unidad</label>
                        <div class="fw-bold">@Model.PlacaUnidad</div>
                        <div class="small text-muted">Capacidad: @Model.Unidad?.CapacidadPasajeros pasajeros</div>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small d-block">Chofer</label>
                        <div class="fw-bold">@Model.Chofer?.Nombre @Model.Chofer?.Apellidos</div>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small d-block">Salida</label>
                        <div class="fw-bold">@Model.FechaHoraSalida.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small d-block">Llegada estimada</label>
                        <div class="fw-bold">@Model.FechaHoraLlegadaEstimada.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small d-block">Estado</label>
                        <span class="badge bg-success">@Model.Estado</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0" style="border-radius:1rem; overflow:hidden;">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0 fw-bold">
                    <i class="bi bi-people-fill me-2 text-primary"></i>Pasajeros Embarcados
                </h5>
                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">
                    @(Model.Reservas?.Count ?? 0) registro(s)
                </span>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-uppercase small text-muted">
                        <tr>
                            <th class="px-4 py-3">Nombre completo</th>
                            <th class="px-4 py-3">Identificación</th>
                            <th class="px-4 py-3 text-center">Asiento</th>
                            <th class="px-4 py-3 text-end">Monto pagado</th>
                            <th class="px-4 py-3 text-center">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Reservas != null && Model.Reservas.Any())
                        {
                            foreach (var reserva in Model.Reservas)
                            {
                                <tr>
                                    <td class="px-4 py-3 fw-semibold">
                                        @reserva.Pasajero?.Nombre @reserva.Pasajero?.Apellidos
                                    </td>
                                    <td class="px-4 py-3">@reserva.IdPasajero</td>
                                    <td class="px-4 py-3 text-center">
                                        <span class="badge bg-primary">@reserva.NumeroAsiento</span>
                                    </td>
                                    <td class="px-4 py-3 text-end fw-bold text-success">
                                        ₡@reserva.MontoPagado.ToString("N2")
                                    </td>
                                    <td class="px-4 py-3 text-center">
                                        <form asp-action="CancelarReserva" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="idReserva" value="@reserva.IdReserva" />
                                            <input type="hidden" name="idViaje" value="@Model.IdViaje" />
                                            <button type="submit"
                                                    class="btn btn-outline-danger btn-sm"
                                                    onclick="return confirm('¿Desea cancelar esta reserva y liberar el asiento?');">
                                                <i class="bi bi-trash3-fill"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-5">
                                    No hay registros de tiquetes vendidos o asientos asignados para este viaje.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
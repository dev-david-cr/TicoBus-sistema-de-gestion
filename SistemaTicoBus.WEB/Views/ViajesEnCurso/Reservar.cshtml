@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    ViewData["Title"] = "Emitir Tiquete";
    ViewData["Seccion"] = "ViajesEnCurso";

    var viaje = ViewBag.Viaje as SistemaTicoBus.MODEL.Entidades.Viaje;
}

<div class="mb-4">
    <a asp-action="Detalles" asp-route-id="@viaje?.IdViaje" class="btn btn-outline-secondary btn-sm fw-bold">
        <i class="bi bi-arrow-left me-1"></i> Volver al Panel de Control
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="card shadow border-0" style="border-radius:1rem; overflow:hidden;">
            <div class="card-header bg-success text-white py-3">
                <h5 class="card-title mb-0 fw-bold">
                    <i class="bi bi-ticket-perforated-fill me-2"></i>Emitir Tiquete / Reservar Asiento
                </h5>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-secondary mb-4 border-0">
                    <div class="row small text-dark">
                        <div class="col-6">
                            <strong>Destino:</strong> @viaje?.Ruta?.Nombre
                        </div>
                        <div class="col-6 text-end">
                            <strong>Tarifa:</strong> ₡@String.Format("{0:N2}", viaje?.Ruta?.PrecioBase)
                        </div>
                    </div>
                </div>

                <form asp-action="Reservar" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" name="idViaje" value="@viaje?.IdViaje" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Pasajero</label>
                        <select name="idPasajero" class="form-select" asp-items="ViewBag.Pasajeros" required>
                            <option value="">Seleccione un pasajero...</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">
                            Número de Asiento Disponible (1 - @viaje?.Unidad?.CapacidadPasajeros)
                        </label>
                        <input type="number"
                               name="numeroAsiento"
                               class="form-control"
                               min="1"
                               max="@viaje?.Unidad?.CapacidadPasajeros"
                               placeholder="Ej: 12"
                               required />
                        <div class="form-text">Asigne un asiento físico disponible dentro de la unidad de transporte.</div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a asp-action="Detalles" asp-route-id="@viaje?.IdViaje" class="btn btn-light fw-bold">Cancelar</a>
                        <button type="submit" class="btn btn-success px-4 fw-bold">Procesar Abordaje</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}
@model SistemaTicoBus.MODEL.Entidades.Viaje

@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    ViewData["Title"] = "Confirmar Cierre de Viaje";
    ViewData["Seccion"] = "ViajesEnCurso";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-lg border-0" style="border-radius:1rem; overflow:hidden;">
            <div class="card-header bg-warning text-dark text-center py-4">
                <h4 class="mb-1 fw-bold">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>Resumen de Recaudación y Cierre
                </h4>
                <span class="text-uppercase small fw-bold">Arqueo Estadístico Final</span>
            </div>
            <div class="card-body p-5">
                <p class="text-muted text-center fs-6 mb-4">
                    Por favor verifique los montos consolidados para el viaje <strong>#@Model.IdViaje</strong>
                    con destino a <strong>@Model.Ruta?.Nombre</strong> antes de confirmar el cierre definitivo de operación.
                </p>

                <div class="row g-3 mb-4">
                    <div class="col-6">
                        <div class="p-3 bg-light rounded border text-center">
                            <label class="text-muted small d-block">Pasajeros Embarcados</label>
                            <span class="fs-4 fw-bold text-dark">@ViewBag.PasajerosEmbarcados</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 bg-light rounded border text-center">
                            <label class="text-muted small d-block">Asientos Libres</label>
                            <span class="fs-4 fw-bold text-secondary">@ViewBag.AsientosDisponibles</span>
                        </div>
                    </div>
                </div>

                <div class="p-4 bg-success-subtle text-success rounded text-center border border-success mb-4">
                    <label class="small d-block text-uppercase fw-bold text-success-emphasis">Total Neto Recaudado</label>
                    <span class="fs-2 fw-bold">₡@String.Format("{0:N2}", ViewBag.TotalRecaudado)</span>
                </div>

                <div class="alert alert-danger d-flex align-items-center border-0 small mb-4" role="alert">
                    <i class="bi bi-info-circle-fill fs-5 me-2 flex-shrink-0"></i>
                    <div>
                        <strong>Atención:</strong> Una vez que cambie el estado del viaje a <strong>Completado</strong>,
                        la operación se dará por cerrada. No se admitirán nuevos tiquetes ni cancelaciones.
                    </div>
                </div>

                <form asp-action="FinalizarViaje" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="idViaje" value="@Model.IdViaje" />

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger btn-lg fw-bold shadow-sm">
                            <i class="bi bi-check-circle-fill me-2"></i>Confirmar y Cerrar Operación
                        </button>
                        <a asp-action="Detalles" asp-route-id="@Model.IdViaje" class="btn btn-link text-secondary text-center mt-2">
                            Cancelar y Mantener Abierto
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
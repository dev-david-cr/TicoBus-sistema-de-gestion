@model List<SistemaTicoBus.MODEL.Entidades.ViajeCancelado>

@{
    ViewData["Title"] = "Viajes Cancelados";
    ViewData["Seccion"] = "ViajesCancelados";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";

    int totalCancelados = Model?.Count ?? 0;
}

<style>
    .banner-cancelados {
        height: 190px;
        border-radius: 14px;
        overflow: hidden;
        background-image: linear-gradient(rgba(0,10,30,.35), rgba(0,10,30,.35)), url('/images/bus-banner.png');
        background-size: cover;
        background-position: center;
        box-shadow: 0 4px 12px rgba(0,0,0,.15);
    }

    .stat-card {
        border-radius: 14px;
        border: 1px solid #d5d9df;
        background: white;
        padding: 22px 26px;
        min-height: 130px;
        position: relative;
        overflow: hidden;
    }

        .stat-card i {
            position: absolute;
            right: 24px;
            top: 24px;
            font-size: 48px;
            color: #d7d9dc;
        }

    .stat-title {
        font-size: 13px;
        font-weight: 700;
        color: #343a40;
        letter-spacing: .5px;
    }

    .stat-number {
        font-size: 28px;
        font-weight: 800;
        color: #000;
    }

    .filter-card {
        border-radius: 14px;
        border: 1px solid #d5d9df;
        background: white;
        padding: 18px;
    }

    .cancel-table-card {
        border-radius: 14px;
        border: 1px solid #d5d9df;
        background: white;
        overflow: hidden;
    }

    .cancel-table th {
        background: #f4f5f6;
        font-size: 12px;
        font-weight: 800;
        letter-spacing: .7px;
        color: #2d333a;
        padding: 18px 24px;
    }

    .cancel-table td {
        padding: 20px 24px;
        vertical-align: middle;
        font-size: 15px;
    }

    .badge-motivo {
        background: #263238;
        color: white;
        border-radius: 20px;
        padding: 6px 12px;
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        display: inline-block;
    }

    .btn-detalle {
        background: #e9ecef;
        border: none;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 700;
        padding: 8px 14px;
        color: #1f2933;
        text-decoration: none;
    }

        .btn-detalle:hover {
            background: #dfe3e6;
            color: #000;
        }
</style>

<div class="container-fluid">

    <div class="banner-cancelados mb-4"></div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="stat-card">
                <i class="bi bi-calendar-x"></i>
                <div class="stat-title">Total Cancelados</div>
                <div class="stat-number">@totalCancelados Viajes</div>
                <div class="text-danger fw-semibold mt-3">
                    Viajes en estado cancelado
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="stat-card">
                <i class="bi bi-percent"></i>
                <div class="stat-title">Tasa de Cancelación (%)</div>
                <div class="stat-number">
                    @(totalCancelados > 0 ? "Activa" : "0%")
                </div>
                <div class="text-success fw-semibold mt-3">
                    Según registros actuales
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="stat-card">
                <i class="bi bi-cash-stack"></i>
                <div class="stat-title">Reembolsos Pendientes</div>
                <div class="stat-number">@totalCancelados</div>
                <div class="text-warning fw-semibold mt-3">
                    Viajes por revisar
                </div>
            </div>
        </div>
    </div>

    <div class="filter-card mb-4">
        <div class="row g-3 align-items-center">
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text bg-white">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" class="form-control" placeholder="Buscar por No. de Viaje o Chofer" />
                </div>
            </div>

            <div class="col-md-3">
                <input type="date" class="form-control" />
            </div>

            <div class="col-md-3">
                <input type="date" class="form-control" />
            </div>

            <div class="col-md-1">
                <button class="btn btn-dark w-100">
                    <i class="bi bi-filter"></i>
                    Filtrar
                </button>
            </div>
        </div>
    </div>

    <div class="cancel-table-card">
        <div class="table-responsive">
            <table class="table cancel-table mb-0">
                <thead>
                    <tr>
                        <th>No. de Viaje</th>
                        <th>Ruta</th>
                        <th>Unidad</th>
                        <th>Chofer</th>
                        <th>Fecha Programada</th>
                        <th>Motivo</th>
                        <th>Reembolso</th>
                        <th>Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var viaje in Model)
                        {
                            <tr>
                                <td>
                                    <strong>#TR-@viaje.NumeroViaje</strong>
                                </td>

                                <td>
                                    @viaje.Ruta
                                </td>

                                <td>
                                    @viaje.PlacaUnidad
                                </td>

                                <td>
                                    @viaje.NombreChofer
                                </td>

                                <td>
                                    @viaje.FechaHoraSalida.ToString("dd MMM, hh:mm tt")
                                </td>

                                <td>
                                    <span class="badge-motivo">
                                        @viaje.MotivoCancelacion
                                    </span>
                                </td>

                                <td>
                                    <span class="text-warning fw-semibold">
                                        <i class="bi bi-clock-history"></i> Pendiente
                                    </span>
                                </td>

                                <td>
                                    <a asp-controller="ViajeCancelado"
                                       asp-action="Detalle"
                                       asp-route-id="@viaje.NumeroViaje"
                                       class="btn-detalle">
                                        Ver Detalles
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">
                                No hay viajes cancelados registrados.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="p-3 bg-light border-top d-flex justify-content-between align-items-center">
            <span class="text-muted">
                Mostrando @(Model?.Count ?? 0) registro(s)
            </span>

            <div>
                <button class="btn btn-outline-secondary btn-sm" disabled>
                    <i class="bi bi-chevron-left"></i>
                </button>
                <button class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </div>
    </div>

</div>
@model IEnumerable<SistemaTicoBus.MODEL.Entidades.Ruta>

@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    ViewData["Title"] = "Catálogo de Rutas";
    ViewData["Seccion"] = "Rutas";

    string busqueda = Context.Request.Query["buscar"].ToString();
}

<div class="mb-4">
    <div class="text-uppercase text-muted fw-bold" style="font-size:0.75rem; letter-spacing:.08em;">
        Operación &gt; Catálogo de Rutas
    </div>
    <h2 class="fw-bold mb-0 mt-2 d-flex align-items-center gap-2">
        <span class="material-symbols-outlined text-success">explore</span>
        Catálogo de Rutas
    </h2>
</div>

<div class="card border-0 shadow-sm mb-4" style="border-radius:1rem;">
    <div class="card-body p-3">
        <form method="get" action="/Rutas/ListadoRutas" class="row g-2">
            <div class="col-md">
                <div class="input-group">
                    <span class="input-group-text bg-white">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text"
                           name="buscar"
                           placeholder="Buscar rutas por nombre o destino..."
                           class="form-control"
                           value="@busqueda" />
                </div>
            </div>
            <div class="col-md-auto d-flex gap-2">
                <button type="submit" class="btn btn-dark fw-bold px-4">Buscar</button>
                @if (!string.IsNullOrWhiteSpace(busqueda))
                {
                    <a href="/Rutas/ListadoRutas" class="btn btn-outline-secondary fw-bold">Limpiar</a>
                }
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm" style="border-radius:1rem;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-uppercase small text-muted">
                    <tr>
                        <th class="px-4 py-3">ID / Nombre</th>
                        <th class="px-4 py-3">Origen</th>
                        <th class="px-4 py-3">Destino</th>
                        <th class="px-4 py-3">Duración</th>
                        <th class="px-4 py-3 text-end">Precio Base</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var ruta in Model)
                        {
                            <tr>
                                <td class="px-4 py-3">
                                    <div class="fw-bold">@ruta.Nombre</div>
                                    <div class="text-muted small">RT-@ruta.Id</div>
                                </td>
                                <td class="px-4 py-3">@ruta.Origen</td>
                                <td class="px-4 py-3">@ruta.Destino</td>
                                <td class="px-4 py-3">@ruta.DuracionEstimada.ToString(@"hh\:mm") h</td>
                                <td class="px-4 py-3 text-end fw-bold text-success">
                                    ₡@ruta.PrecioBase.ToString("N0")
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="px-4 py-5 text-center text-muted">
                                <i class="bi bi-info-circle fs-4 d-block mb-2"></i>
                                No se encontraron rutas disponibles en este momento.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>